# 로컬 개발용 환경변수 양식 — 실제 값은 .env.local에 작성 (git에 올라가지 않음)
# 값 위치: Supabase 대시보드 → 프로젝트 → Settings → API

SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# 서버 전용 관리자 키. 절대 커밋 금지.
# 신형 Secret key(sb_secret_...) 또는 기존 service_role JWT 중 아무거나 붙여넣으면 됩니다.
SUPABASE_SERVICE_ROLE_KEY=

# 기존 Lovable Supabase Storage 읽기 전용 연결.
# URL은 생략하면 기존 프로젝트(tgybttphkmesgfbtgftt)를 사용합니다.
SOURCE_SUPABASE_URL=
SOURCE_SUPABASE_PUBLISHABLE_KEY=

# AI 기능용 Google Gemini API Key
GEMINI_API_KEY=

